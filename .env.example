# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Data Science resources.
# Untuk development, arahkan ke submodule data_science_resources.
DS_RESOURCES_DIR=./data_science_resources
DS_ASSET_AUTO_RELOAD=true

# Optional specific overrides
# ROLE_TREE_DROPDOWN_PATH=./data_science_resources/role_tree_dropdown.json
# ROLE_SKILL_MATRIX_PATH=./data_science_resources/role_skill_matrix.json
# SKILL_TAXONOMY_PATH=./data_science_resources/skill_taxonomy.json
# COMPETENCY_MAP_PATH=./data_science_resources/competency_map.json
# QUESTION_SEED_PATH=./data_science_resources/question_seed.json
# WEAKNESS_TAXONOMY_PATH=./data_science_resources/weakness_taxonomy.json
# SCORING_RUBRIC_PATH=./data_science_resources/scoring_rubric.json
# EVIDENCE_LADDER_MAPPING_PATH=./data_science_resources/evidence_ladder_mapping.json
# ANSWER_QUALITY_DATASET_PATH=./data_science_resources/answer_quality_dataset_synthetic.csv
# ANSWER_QUALITY_MANUAL_TEST_PATH=./data_science_resources/answer_quality_manual_test.csv

# Model outputs
MODEL_DIR=./models
ANSWER_QUALITY_MODEL_PATH=./models/answer_quality_model.keras
ANSWER_QUALITY_TOKENIZER_PATH=./models/answer_quality_tokenizer.json
ANSWER_QUALITY_META_PATH=./models/answer_quality_meta.json

# Interview config
MAX_MAIN_QUESTIONS=3
MAX_CLARIFICATIONS_PER_MAIN=1
