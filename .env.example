# Gemini / GenAI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Data Science resources
DS_RESOURCES_DIR=./data_science_resources
DS_ASSET_AUTO_RELOAD=true
ROLE_TREE_DROPDOWN_PATH=
ROLE_SKILL_MATRIX_PATH=
SKILL_TAXONOMY_PATH=
COMPETENCY_MAP_PATH=
QUESTION_SEED_PATH=
WEAKNESS_TAXONOMY_PATH=
SCORING_RUBRIC_PATH=
EVIDENCE_LADDER_MAPPING_PATH=
ANSWER_QUALITY_TRAIN_PATH=./data_science_resources/dataset_train.csv
ANSWER_QUALITY_VAL_PATH=./data_science_resources/dataset_val.csv
ANSWER_QUALITY_TEST_PATH=./data_science_resources/dataset_test.csv
ANSWER_QUALITY_DATASET_PATH=./data_science_resources/answer_quality_dataset_synthetic.csv
ANSWER_QUALITY_MANUAL_TEST_PATH=./data_science_resources/answer_quality_manual_test.csv

# Interview business rules
MAX_MAIN_QUESTIONS=5
MIN_MAIN_QUESTIONS=3
MAX_CLARIFICATION_PER_MAIN=1
MAX_CLARIFICATION_PER_SESSION=3
MAX_AUDIO_DURATION_SECONDS=90
MAX_AUDIO_FILE_SIZE_MB=25
STT_LOW_CONFIDENCE_THRESHOLD=0.60

# TensorFlow model paths
MODEL_DIR=./models
ANSWER_QUALITY_MODEL_PATH=./models/answer_quality_model.keras
ANSWER_QUALITY_TOKENIZER_PATH=./models/answer_quality_tokenizer.json
ANSWER_QUALITY_META_PATH=./models/answer_quality_meta.json
